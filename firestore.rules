rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Rule dasar: hanya user terautentikasi yang bisa akses
    match /users/{uid} {

      // Setiap user hanya bisa baca/tulis dokumennya sendiri
      // KECUALI promptCache — bisa dibaca semua user terautentikasi
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Subcollection examMode — aturan sama dengan parent
      match /examMode/{document} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Cache jawaban (promptCache) — semua user terautentikasi bisa baca,
    // tapi hanya bisa nulis jika data belum ada (cegah overwrite)
    match /promptCache/{hash} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.keys().hasAll(['prompt', 'answer', 'cachedAt']);
      allow update: if false; // tidak boleh di-update, sekali simpan tetap
      allow delete: if false; // tidak boleh dihapus
    }

    // Rule default: tolak semua yang tidak cocok di atas
    match /{document=**} {
      allow read, write: if false;
    }
  }
}